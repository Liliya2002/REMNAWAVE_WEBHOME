# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGUSER=vpn_user
PGPASSWORD=vpn_pass
PGDATABASE=vpn_db

# JWT
JWT_SECRET=your_jwt_secret_here

# Server
PORT=4000
FRONTEND_URL=http://localhost:5173

# Production-домен (используется в nginx-конфиге, vite-сборке, CORS, sitemap)
DOMAIN=example.com
# CORS-источники, запятая-разделитель. В production должен быть https://${DOMAIN}
CORS_ORIGINS=http://localhost:5173,https://example.com
# URL фронта в production (для VITE_API_URL — base API URL)
VITE_API_URL=https://example.com

# Platega.io Payment Gateway
# Получите в личном кабинете Platega.io: Настройки → API ключи
PLATEGA_MERCHANT_ID=your_merchant_id_here
PLATEGA_SECRET=your_platega_secret_here

# Remnwave API
REMNWAVE_API_URL=https://panel-root.guard-proxy.pro
REMNWAVE_API_TOKEN=your_token_here
REMNWAVE_SECRET_KEY=your_secret_key_here

# Webhook (HMAC-SHA256 подпись входящих webhook от Remnwave)
# Сгенерировать:  openssl rand -hex 32
# Обязательна: если не задан, все webhook будут отклонены с 401.
WEBHOOK_SECRET=your_webhook_secret_here

# Шифрование чувствительных данных в БД (SSH-пароли/ключи VPS, и т.п.)
# Сгенерировать:  openssl rand -hex 32
# В production обязателен — без него процесс не стартует.
# Менять нельзя — все зашифрованные данные станут нечитаемыми.
# При первом задании запустите миграцию:  node backend/scripts/migrate_encrypt_ssh.js
ENCRYPTION_KEY=your_encryption_key_here

# GitHub: для проверки обновлений в админке (/admin/system).
# Формат "owner/repo", например GITHUB_REPO=artur-bulikyan/vpnwebhome
# GITHUB_TOKEN — опционально, повышает rate-limit с 60 до 5000 req/час.
GITHUB_REPO=
GITHUB_TOKEN=

# Build metadata — задаются Dockerfile build-args, не нужно править руками.
# BUILD_SHA=
# BUILD_DATE=

# Docker images — для production-compose, чтобы тянуть готовые образы из ghcr.io
# IMAGE_NAMESPACE = "owner/repo" в lowercase, например artur-bulikyan/vpnwebhome
# VERSION = какую версию деплоить (например 1.0.0). По умолчанию latest.
# IMAGE_REGISTRY = ghcr.io (можно не задавать)
IMAGE_NAMESPACE=
VERSION=latest
# IMAGE_REGISTRY=ghcr.io

# Deploy-runner — отдельный контейнер для запуска deploy.sh из админки.
# DEPLOY_TOKEN: общий секрет для backend↔runner. Минимум 16 символов.
#   Сгенерировать: openssl rand -hex 32
# DEPLOY_RUNNER_URL: внутренний URL runner-а (для backend). Не выставлять наружу.
DEPLOY_TOKEN=
DEPLOY_RUNNER_URL=http://deploy-runner:4100

# Telegram Bot (для уведомлений об истечении VPS)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Telegram Login (авторизация через Telegram)
# Тот же TELEGRAM_BOT_TOKEN используется для верификации данных от Telegram Login Widget

# Автоматическое уведомление об истечении VPS (cron)
TG_VPS_NOTIFY_ENABLED=false
TG_VPS_NOTIFY_HOUR=10

# Hosting Catalog Integration (внешний сервер каталога VPS)
# URL API каталога офферов (пример: https://catalog.example.com/v1/catalog/offers)
# HOSTING_CATALOG_URL=
# Токен доступа к внешнему API (Bearer/x-api-key)
# HOSTING_CATALOG_TOKEN=
# Включить авто-синхронизацию без ручных нажатий
# HOSTING_CATALOG_AUTO_SYNC_ENABLED=true
# Интервал авто-синхронизации в минутах
# HOSTING_CATALOG_AUTO_SYNC_MINUTES=15
